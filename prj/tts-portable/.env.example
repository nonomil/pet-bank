# ============================================================
# 本地 TTS 实时服务 - 环境变量样例
# 用法：复制本文件为 .env（或直接在系统/启动脚本里 set/export 这些变量）
# ============================================================

# VoxCPM2 虚拟环境 python 路径（需 NVIDIA GPU）。
# 留空或路径不存在 → 服务自动降级到 edge-tts（云端，无需 GPU）。
VOXCPM2_PYTHON=D:/PythonEnvs/tts-voxcpm/Scripts/python.exe

# VoxCPM2 本地模型路径（复用已下好的权重，免下载）。
# 指向扁平目录（含 model.safetensors / audiovae.pth / config.json 等）。
# 留空 → 回退在线名 openbmb/VoxCPM2（需联网下载，建议配合下面的 HF_ENDPOINT 镜像）。
VOXCPM2_MODEL_PATH=D:/HuggingFaceCache/VoxCPM2

# VoxCPM2 子进程超时（秒）。冷启动 import torch + 加载模型 + generate 常 >120s，默认 300。
VOXCPM2_TIMEOUT=300

# 服务监听地址。127.0.0.1=仅本机；0.0.0.0=局域网/容器可访问。
TTS_HOST=127.0.0.1

# 服务监听端口（默认 9885，避开常见 LLM 代理端口 8765）。
TTS_PORT=9885

# 国内 HuggingFace 镜像（VoxCPM2 在线下载加速，避免卡死；start 脚本已默认设置）。
HF_ENDPOINT=https://hf-mirror.com

# HuggingFace token（可选，解除匿名下载限速；公开模型一般不需要）。
# HF_TOKEN=hf_xxxxx
