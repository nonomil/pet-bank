  "scenes": [
    {
      "sceneId": "village",
      "background": "assets/story/pixel-worlds-v1/scenes/block/block-01.webp",
      "lines": [
        {
          "type": "narration",
          "text": "穿过古树门，小小探险家来到方块村。村口的路牌倒在草地上，大家找不到地下城的方向。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里是“方块村门口：搭起路牌”。我们的任务是“把路牌的方块一块块搭起来”，先看清村口路牌，再决定下一步。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "方块碰撞和远处的机关声告诉我，村口路牌就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "在方块村门口：搭起路牌，发现问题不能只靠着急。我们要一步一步搭出安全的路线，先处理村口路牌，也要照顾身边的朋友。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "build",
          "prompt": "把路牌的方块一块块搭起来，让村口路牌的线索显现出来。",
          "character": "hero",
          "position": "left",
          "actions": [
            {
              "label": "放上木方块",
              "feedback": "放上木方块后，村口路牌出现了；矿洞火把路的方向更清楚了。"
            },
            {
              "label": "装上小灯",
              "feedback": "装上小灯让另一个细节亮起来：方标记指向矿洞火把路。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "村口路牌被找到后，矿洞火把路的方向亮了起来。一步一步搭出安全的路线，新的道路出现了。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "原来“方”也藏在这里。我们把它和地图上的光点连起来。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听见矿洞火把路传来的声音了，刚才的努力真的让它更近了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "村口路牌让大家知道，矿洞火把路不是远处的名字，而是一条可以走到的路。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "这件事提醒我们：村口路牌不是终点，它会把故事带到矿洞火把路。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "完成这一站后，矿洞火把路的入口已经亮起。我们带着“方”继续走。",
          "character": "block_builder",
          "position": "right"
        }
      ],
      "sceneAssets": {
