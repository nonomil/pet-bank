      "sceneAssets": {
        "characters": [
          "narrator",
          "hero",
          "pet",
          "block_builder"
        ],
        "props": [
          "assets/story/pixel-worlds-v1/props/block/block-08.webp"
        ]
      },
      "lines": [
        {
          "type": "narration",
          "text": "方块农场正在发生变化。现在是“收集线索”的一步：我们要找到方块麦穗，再把线索送向石砖广场。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里是“方块农场”。我们的任务是“收集成熟的方块麦穗”，先看清方块麦穗，再决定下一步。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "方块碰撞和远处的机关声告诉我，方块麦穗就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "在方块农场，收集线索不能只靠着急。我们要一步一步搭出安全的路线，先处理方块麦穗，也要照顾身边的朋友。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "collect",
          "prompt": "收集成熟的方块麦穗，让方块麦穗的线索显现出来。",
          "character": "block_builder",
          "position": "right",
          "actions": [
            {
              "label": "收下金色麦穗",
              "feedback": "收下金色麦穗后，方块麦穗出现了；石砖广场的方向更清楚了。"
            },
            {
              "label": "给小鸡留一把",
              "feedback": "给小鸡留一把让另一个细节亮起来：麦标记指向石砖广场。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "方块麦穗被找到后，石砖广场的方向亮了起来。一步一步搭出安全的路线，新的道路出现了。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "原来“麦”也藏在这里。我们把它和地图上的光点连起来。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听见石砖广场传来的声音了，刚才的努力真的让它更近了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "方块麦穗让大家知道，石砖广场不是远处的名字，而是一条可以走到的路。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "这件事提醒我们：方块麦穗不是终点，它会把故事带到石砖广场。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "完成这一站后，石砖广场的入口已经亮起。我们带着“麦”继续走。",
          "character": "pet",
          "position": "right"
        }
      ]
    }
  ],
  "storyVersion": 2,
  "icon": "assets/story/pixel-worlds-v1/icons/block/safe-mine-cart.webp"
