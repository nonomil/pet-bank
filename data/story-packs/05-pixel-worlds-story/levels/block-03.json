  "scenes": [
    {
      "sceneId": "waterway",
      "background": "assets/story/pixel-worlds-v1/scenes/block/block-03.webp",
      "lines": [
        {
          "type": "narration",
          "text": "地下水渠被一块石门挡住了。村里的小花田正在等水。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里是“地下水渠：引水回家”。我们的任务是“转动水渠方块，让水流向花田”，先看清回家的水渠，再决定下一步。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "方块碰撞和远处的机关声告诉我，回家的水渠就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "在地下水渠：引水回家，发现问题不能只靠着急。我们要一步一步搭出安全的路线，先处理回家的水渠，也要照顾身边的朋友。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "route",
          "prompt": "转动水渠方块，让水流向花田，让回家的水渠的线索显现出来。",
          "character": "block_builder",
          "position": "right",
          "actions": [
            {
              "label": "转动蓝色水块",
              "feedback": "转动蓝色水块后，回家的水渠出现了；红石工坊的方向更清楚了。"
            },
            {
              "label": "打开石门机关",
              "feedback": "打开石门机关让另一个细节亮起来：水标记指向红石工坊。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "回家的水渠被找到后，红石工坊的方向亮了起来。一步一步搭出安全的路线，新的道路出现了。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "原来“水”也藏在这里。我们把它和地图上的光点连起来。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听见红石工坊传来的声音了，刚才的努力真的让它更近了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "回家的水渠让大家知道，红石工坊不是远处的名字，而是一条可以走到的路。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "这件事提醒我们：回家的水渠不是终点，它会把故事带到红石工坊。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "完成这一站后，红石工坊的入口已经亮起。我们带着“水”继续走。",
          "character": "block_builder",
          "position": "right"
        }
      ],
