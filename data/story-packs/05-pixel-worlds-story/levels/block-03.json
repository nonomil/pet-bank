  "scenes": [
    {
      "sceneId": "waterway",
      "background": "assets/story/pixel-worlds-v1/scenes/block/block-03.webp",
      "lines": [
        {
          "type": "narration",
          "text": "地下水渠被一块石门挡住了。村里的小花田正在等水。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里就是地下水渠。我们先把“引水回家”记在地图上。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听到方块碰撞的声音，新的建造点就在前面。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "先找稳固的方块，再一步一步搭出安全的路线。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "route",
          "prompt": "转动水渠方块，让水流向花田。",
          "character": "block_builder",
          "position": "right",
          "actions": [
            {
              "label": "转动蓝色水块",
              "feedback": "水流沿着水渠快乐地跑起来。"
            },
            {
              "label": "打开石门机关",
              "feedback": "石门升起，清水流到了花田。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "小小探险家完成了第一步，转动蓝色水块让周围的线索变得清楚起来。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "看！刚才藏起来的线索露出来了。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "方块放稳后，藏在墙后的通道露出来了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "把这段通道接到村子的道路上，伙伴们就能一起通过。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "记住这块特别的方块，它会成为下一座建筑的起点。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "‘水’会走很远，也会把生命带到很远的地方。",
          "character": "block_builder",
          "position": "right"
        }
      ],
      "sceneAssets": {
