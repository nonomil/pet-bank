  "scenes": [
    {
      "sceneId": "block-07-scene-1",
      "background": "assets/story/pixel-worlds-v1/scenes/block/block-07.webp",
      "sceneAssets": {
        "characters": [
          "narrator",
          "hero",
          "pet",
          "block_builder"
        ],
        "props": [
          "assets/story/pixel-worlds-v1/props/block/block-07.webp"
        ]
      },
      "lines": [
        {
          "type": "narration",
          "text": "木门小路正在发生变化。现在是“收集线索”的一步：我们要找到木门通道，再把线索送向方块农场。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里是“木门小路”。我们的任务是“把两块木板搭成地下城入口”，先看清木门通道，再决定下一步。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "方块碰撞和远处的机关声告诉我，木门通道就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "在木门小路，收集线索不能只靠着急。我们要一步一步搭出安全的路线，先处理木门通道，也要照顾身边的朋友。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "build",
          "prompt": "把两块木板搭成地下城入口，让木门通道的线索显现出来。",
          "character": "block_builder",
          "position": "right",
          "actions": [
            {
              "label": "放上木板",
              "feedback": "放上木板后，木门通道出现了；方块农场的方向更清楚了。"
            },
            {
              "label": "挂上蓝灯",
              "feedback": "挂上蓝灯让另一个细节亮起来：路标记指向方块农场。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "木门通道被找到后，方块农场的方向亮了起来。一步一步搭出安全的路线，新的道路出现了。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "原来“路”也藏在这里。我们把它和地图上的光点连起来。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听见方块农场传来的声音了，刚才的努力真的让它更近了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "木门通道让大家知道，方块农场不是远处的名字，而是一条可以走到的路。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "这件事提醒我们：木门通道不是终点，它会把故事带到方块农场。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "完成这一站后，方块农场的入口已经亮起。我们带着“路”继续走。",
          "character": "pet",
          "position": "right"
        }
      ]
    }
  ],
  "storyVersion": 2,
