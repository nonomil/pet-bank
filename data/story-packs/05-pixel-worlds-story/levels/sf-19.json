        "props": [
          "assets/story/pixel-worlds-v1/props/sci-fi/sf-19.webp"
        ]
      },
      "lines": [
        {
          "type": "narration",
          "text": "小小探险家来到导航塔顶。从星图上找到下一颗绿色星标。，新的线索正在等着被发现。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里就是导航塔顶。我们先把“读懂星图”记在地图上。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听到光核在轻轻嗡鸣，信号就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "先看清蓝色航线，再做一个安全的小动作。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "scan",
          "prompt": "从星图上找到下一颗绿色星标。",
          "character": "star_engineer",
          "position": "right",
          "actions": [
            {
              "label": "点亮绿色星标",
              "feedback": "森林地图被放大，入口清楚了。"
            },
            {
              "label": "转动望远镜",
              "feedback": "望远镜看见了树屋的灯。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "小小探险家完成了第一步，点亮绿色星标让周围的线索变得清楚起来。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "看！刚才藏起来的线索露出来了。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "扫描光点后，隐藏的星尘轨迹露出来了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "把这条轨迹和星图接起来，下一站就会亮起。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "记住这束光，它会带我们穿过下一段星际航线。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "做完这一小步，回家的星图又亮了一格。我们继续出发吧！",
          "character": "pet",
          "position": "right"
        }
      ]
    }
  ],
  "storyVersion": 2
}
