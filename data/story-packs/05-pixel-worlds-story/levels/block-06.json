  "scenes": [
    {
      "sceneId": "gate",
      "background": "assets/story/pixel-worlds-v1/scenes/block/block-06.webp",
      "lines": [
        {
          "type": "narration",
          "text": "星门晶石放进地下城中央，三张地图的光一起聚拢。科幻、森林和方块世界终于连成了一条路。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里是“地下城星门：唤醒回家门”。我们的任务是“给星门放上最后一颗温暖的伙伴之心”，先看清三界星门，再决定下一步。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "方块碰撞和远处的机关声告诉我，三界星门就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "在地下城星门：唤醒回家门，收集线索不能只靠着急。我们要一步一步搭出安全的路线，先处理三界星门，也要照顾身边的朋友。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "care",
          "prompt": "给星门放上最后一颗温暖的伙伴之心，让三界星门的线索显现出来。",
          "character": "pet",
          "position": "right",
          "actions": [
            {
              "label": "放上伙伴之心",
              "feedback": "放上伙伴之心后，三界星门出现了；木门小路的方向更清楚了。"
            },
            {
              "label": "和朋友击掌",
              "feedback": "和朋友击掌让另一个细节亮起来：门标记指向木门小路。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "三界星门被找到后，木门小路的方向亮了起来。一步一步搭出安全的路线，新的道路出现了。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "原来“门”也藏在这里。我们把它和地图上的光点连起来。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听见木门小路传来的声音了，刚才的努力真的让它更近了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "三界星门让大家知道，木门小路不是远处的名字，而是一条可以走到的路。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "这件事提醒我们：三界星门不是终点，它会把故事带到木门小路。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "完成这一站后，木门小路的入口已经亮起。我们带着“门”继续走。",
          "character": "narrator",
          "position": "center"
        }
      ],
