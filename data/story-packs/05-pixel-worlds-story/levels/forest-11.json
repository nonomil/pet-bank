  "scenes": [
    {
      "sceneId": "forest-11-scene-1",
      "background": "assets/story/pixel-worlds-v1/scenes/forest/forest-11.webp",
      "sceneAssets": {
        "characters": [
          "narrator",
          "hero",
          "pet",
          "forest_guide"
        ],
        "props": [
          "assets/story/pixel-worlds-v1/props/forest/forest-11.webp"
        ]
      },
      "lines": [
        {
          "type": "narration",
          "text": "风的广场正在发生变化。现在是“遇到困难”的一步：我们要找到会飞叶片，再把线索送向雨滴工坊。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里是“风的广场”。我们的任务是“找出风吹过的那片叶子”，先看清会飞叶片，再决定下一步。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "树叶、溪水和萤火虫的声音告诉我，会飞叶片就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "在风的广场，遇到困难不能只靠着急。我们要用温柔的动作帮助森林朋友，先处理会飞叶片，也要照顾身边的朋友。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "scan",
          "prompt": "找出风吹过的那片叶子，让会飞叶片的线索显现出来。",
          "character": "forest_guide",
          "position": "right",
          "actions": [
            {
              "label": "追随旋转叶子",
              "feedback": "追随旋转叶子后，会飞叶片出现了；雨滴工坊的方向更清楚了。"
            },
            {
              "label": "听树梢声音",
              "feedback": "听树梢声音让另一个细节亮起来：叶标记指向雨滴工坊。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "会飞叶片被找到后，雨滴工坊的方向亮了起来。用温柔的动作帮助森林朋友，新的道路出现了。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "原来“叶”也藏在这里。我们把它和地图上的光点连起来。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听见雨滴工坊传来的声音了，刚才的努力真的让它更近了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "会飞叶片让大家知道，雨滴工坊不是远处的名字，而是一条可以走到的路。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "这件事提醒我们：会飞叶片不是终点，它会把故事带到雨滴工坊。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "完成这一站后，雨滴工坊的入口已经亮起。我们带着“叶”继续走。",
          "character": "pet",
          "position": "right"
        }
      ]
    }
  ],
  "storyVersion": 2,
  "icon": "assets/story/pixel-worlds-v1/icons/forest/mossy-stepping-stone.webp"
}
