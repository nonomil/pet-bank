  "scenes": [
    {
      "sceneId": "forest-11-scene-1",
      "background": "assets/story/pixel-worlds-v1/scenes/forest/forest-11.webp",
      "sceneAssets": {
        "characters": [
          "narrator",
          "hero",
          "pet",
          "forest_guide"
        ],
        "props": [
          "assets/story/pixel-worlds-v1/props/forest/forest-11.webp"
        ]
      },
      "lines": [
        {
          "type": "narration",
          "text": "小小探险家来到风的广场。找出风吹过的那片叶子。，新的线索正在等着被发现。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里就是风的广场。我们先把“听风说话”记在地图上。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我闻到了叶子和雨水的味道，森林朋友就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "先听树叶的声音，再用温柔的动作帮助这里的朋友。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "scan",
          "prompt": "找出风吹过的那片叶子。",
          "character": "forest_guide",
          "position": "right",
          "actions": [
            {
              "label": "追随旋转叶子",
              "feedback": "叶子落到一块写着‘风’的石头旁。"
            },
            {
              "label": "听树梢声音",
              "feedback": "风声变成了轻轻的口哨。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "小小探险家完成了第一步，追随旋转叶子让周围的线索变得清楚起来。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "看！刚才藏起来的线索露出来了。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "轻轻完成这一步，藏在叶影里的小路出现了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "把这条小路和森林地图连起来，萤光就会为我们领路。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "记住这片叶子的形状，下一次遇见它就知道该往哪里走。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "做完这一小步，回家的星图又亮了一格。我们继续出发吧！",
          "character": "pet",
          "position": "right"
        }
      ]
    }
  ],
  "storyVersion": 2,
  "icon": "assets/story/pixel-worlds-v1/icons/forest/mossy-stepping-stone.webp"
