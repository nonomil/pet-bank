  "scenes": [
    {
      "sceneId": "bridge",
      "background": "assets/story/pixel-worlds-v1/scenes/sci-fi/sf-07.webp",
      "lines": [
        {
          "type": "narration",
          "text": "两颗小星星隔着一片黑色的宇宙。最后一段星桥，等着我们把它连起来。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里就是双星桥。我们先把“连接两颗星”记在地图上。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听到光核在轻轻嗡鸣，信号就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "先看清蓝色航线，再做一个安全的小动作。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "route",
          "prompt": "选择一块会发光的桥片，连接两颗小星。",
          "character": "hero",
          "position": "left",
          "actions": [
            {
              "label": "接上星光桥片",
              "feedback": "桥片伸展开，两颗星星笑了。"
            },
            {
              "label": "摇响回家铃",
              "feedback": "铃声传过宇宙，桥片也亮了起来。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "小小探险家完成了第一步，接上星光桥片让周围的线索变得清楚起来。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "看！刚才藏起来的线索露出来了。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "扫描光点后，隐藏的星尘轨迹露出来了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "把这条轨迹和星图接起来，下一站就会亮起。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "记住这束光，它会带我们穿过下一段星际航线。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "‘连’就是把分开的东西接在一起。我们也连在一起。",
          "character": "pet",
          "position": "right"
        }
      ],
