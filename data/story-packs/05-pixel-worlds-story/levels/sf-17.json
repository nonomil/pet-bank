        ],
        "props": [
          "assets/story/pixel-worlds-v1/props/sci-fi/sf-17.webp"
        ]
      },
      "lines": [
        {
          "type": "narration",
          "text": "小小探险家来到记忆舱。保存今天认识的朋友图像。，新的线索正在等着被发现。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里就是记忆舱。我们先把“保存朋友”记在地图上。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听到光核在轻轻嗡鸣，信号就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "先看清蓝色航线，再做一个安全的小动作。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "collect",
          "prompt": "保存今天认识的朋友图像。",
          "character": "star_engineer",
          "position": "right",
          "actions": [
            {
              "label": "保存森林向导",
              "feedback": "向导的笑容变成一颗绿光。"
            },
            {
              "label": "保存方块工匠",
              "feedback": "工匠挥挥手，变成一颗橙光。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "小小探险家完成了第一步，保存森林向导让周围的线索变得清楚起来。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "看！刚才藏起来的线索露出来了。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "扫描光点后，隐藏的星尘轨迹露出来了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "把这条轨迹和星图接起来，下一站就会亮起。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "记住这束光，它会带我们穿过下一段星际航线。",
          "character": "star_engineer",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "做完这一小步，回家的星图又亮了一格。我们继续出发吧！",
          "character": "pet",
          "position": "right"
        }
      ]
    }
  ],
