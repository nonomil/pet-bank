  "scenes": [
    {
      "sceneId": "workshop",
      "background": "assets/story/pixel-worlds-v1/scenes/block/block-04.webp",
      "lines": [
        {
          "type": "narration",
          "text": "红石工坊里，机关门一会儿开、一会儿关。最后一枚星门晶石就在里面。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里是“红石工坊：修复机关”。我们的任务是“把红石线接回发光的机关”，先看清红石机关，再决定下一步。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "方块碰撞和远处的机关声告诉我，红石机关就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "在红石工坊：修复机关，发现问题不能只靠着急。我们要一步一步搭出安全的路线，先处理红石机关，也要照顾身边的朋友。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "repair",
          "prompt": "把红石线接回发光的机关，让红石机关的线索显现出来。",
          "character": "hero",
          "position": "left",
          "actions": [
            {
              "label": "接上红石线",
              "feedback": "接上红石线后，红石机关出现了；遗迹图书馆的方向更清楚了。"
            },
            {
              "label": "按下启动按钮",
              "feedback": "按下启动按钮让另一个细节亮起来：工标记指向遗迹图书馆。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "红石机关被找到后，遗迹图书馆的方向亮了起来。一步一步搭出安全的路线，新的道路出现了。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "原来“工”也藏在这里。我们把它和地图上的光点连起来。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听见遗迹图书馆传来的声音了，刚才的努力真的让它更近了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "红石机关让大家知道，遗迹图书馆不是远处的名字，而是一条可以走到的路。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "这件事提醒我们：红石机关不是终点，它会把故事带到遗迹图书馆。",
          "character": "block_builder",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "完成这一站后，遗迹图书馆的入口已经亮起。我们带着“工”继续走。",
          "character": "block_builder",
          "position": "right"
        }
      ],
