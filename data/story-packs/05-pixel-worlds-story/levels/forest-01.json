  "scenes": [
    {
      "sceneId": "gate",
      "background": "assets/story/pixel-worlds-v1/scenes/forest/forest-01.webp",
      "lines": [
        {
          "type": "narration",
          "text": "星门把小小探险家送到森林入口。阳光穿过树叶，地上留下了一串圆圆的脚印。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "这里是“森林入口：发现脚印”。我们的任务是“找出通往森林深处的脚印”，先看清圆脚印，再决定下一步。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "树叶、溪水和萤火虫的声音告诉我，圆脚印就在附近。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "在森林入口：发现脚印，发现问题不能只靠着急。我们要用温柔的动作帮助森林朋友，先处理圆脚印，也要照顾身边的朋友。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "activity",
          "activityType": "scan",
          "prompt": "找出通往森林深处的脚印，让圆脚印的线索显现出来。",
          "character": "forest_guide",
          "position": "right",
          "actions": [
            {
              "label": "观察圆脚印",
              "feedback": "观察圆脚印后，圆脚印出现了；萤火溪的方向更清楚了。"
            },
            {
              "label": "看看树叶路牌",
              "feedback": "看看树叶路牌让另一个细节亮起来：森标记指向萤火溪。"
            }
          ]
        },
        {
          "type": "narration",
          "text": "圆脚印被找到后，萤火溪的方向亮了起来。用温柔的动作帮助森林朋友，新的道路出现了。",
          "character": "narrator"
        },
        {
          "type": "dialogue",
          "text": "原来“森”也藏在这里。我们把它和地图上的光点连起来。",
          "character": "hero",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "我听见萤火溪传来的声音了，刚才的努力真的让它更近了。",
          "character": "pet",
          "position": "right"
        },
        {
          "type": "dialogue",
          "text": "圆脚印让大家知道，萤火溪不是远处的名字，而是一条可以走到的路。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "这件事提醒我们：圆脚印不是终点，它会把故事带到萤火溪。",
          "character": "forest_guide",
          "position": "left"
        },
        {
          "type": "dialogue",
          "text": "完成这一站后，萤火溪的入口已经亮起。我们带着“森”继续走。",
          "character": "forest_guide",
          "position": "right"
        }
      ],
