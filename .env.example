# 复制为 .env 并填入真实值（.env 不入库）。
# 浏览器不读取此文件；生产环境由 VPS 上的 Node.js API 使用。
# API 完成后，前端通过同域 /api/v1 访问，不把数据库密钥下发到浏览器。

HFLLM_BASE_URL=https://opencode.ai/zen/go/v1/chat/completions
HFLLM_MODEL=deepseek-v4-flash
HFLLM_TOKEN=sk-你的token

APP_BASE_URL=http://127.0.0.1:7000
PETBANK_API_BASE_URL=http://127.0.0.1:3000/api/v1
PETBANK_DATA_DIR=./data
PETBANK_JWT_SECRET=replace-with-openssl-rand-hex-32-output
PETBANK_ALLOWED_ORIGIN=http://127.0.0.1:7000
PETBANK_ENABLE_REGISTRATION=true
