# Production deployment template for pet-bank.
# Copy to a secure secret store or CI environment, never commit real values.

APP_BASE_URL=https://your-domain.example.com
PETBANK_API_BASE_URL=/api/v1
PETBANK_DATA_DIR=/data
PETBANK_JWT_SECRET=replace-with-openssl-rand-hex-32-output
PETBANK_ALLOWED_ORIGIN=https://your-domain.example.com
PETBANK_ENABLE_REGISTRATION=true
PETBANK_REQUIRE_REGISTRATION_CODE=true

HERMES_DEPLOY_ENV=production
HERMES_HEALTHCHECK_URL=https://your-domain.example.com/api/v1/health
